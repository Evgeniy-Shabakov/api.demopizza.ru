model Employee {
   id Int @id @default(autoincrement())

   phone           String    @unique @db.VarChar(30)
   phoneVerifiedAt DateTime? @map("phone_verified_at")
   email           String?   @unique @db.VarChar(255)
   emailVerifiedAt DateTime? @map("email_verified_at")
   password        String?   @db.VarChar(255)
   firstName       String?   @map("first_name") @db.VarChar(255)
   lastName        String?   @map("last_name") @db.VarChar(255)
   middleName      String?   @map("middle_name") @db.VarChar(255)
   jobTitle        String?   @map("job_title") @db.VarChar(255)

   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

   refreshTokens RefreshToken[]
   employeeRoles EmployeeRole[]

   ordersForResponsibleEmployee Order[] @relation("ResponsibleEmployee")
   ordersForCourier             Order[] @relation("Courier")

   @@map("employees")
}
