GET {{host}}/orders/2

###
POST {{host}}/orders
content-type: application/json

{
   // userId - необязательный параметр, т.к. заказ может быть создан администратором без указания
   // номера телефона пользователя (клиент подходит к админу и просто делает заказ)
   "userId": 3,
   "cityId": 1,
   // deliveryZoneId - необязательный параметр, нужен только при заказе до адреса (orderTypeId == 1)
   "deliveryZoneId": 1,
   // restaurantId - необязательный параметр, нужен когда заказ не до адреса (orderTypeId != 1)
   "restaurantId": 1,
   // userAddressId - необязательный параметр, нужен только при заказе до адреса (orderTypeId == 1)
   "userAddressId": null,
   
   "orderTypeId": 2,
   // tableNumber - необязательный параметр, нужен только при заказе к столику (orderTypeId == 5)
   "tableNumber": null,
   // carNumber - необязательный параметр, нужен только при заказе на парковку (orderTypeId == 6)
   "carNumber": null,
   // packTakeaway - необязательный параметр, (orderTypeId == 4 && 5)
   "packTakeaway": null,
   // leaveAtTheDoor - оставить заказ у двери, необязательный параметр, (orderTypeId == 1)
   "leaveAtTheDoor": null,
   // dontRingDoorbell - не звонить в дверь, необязательный параметр, (orderTypeId == 1)
   "dontRingDoorbell": null,

   "totalProductsPrice": 500,
   "deliveryPrice": 200,
   "bonusCoinsPaid": 100,
   "totalPrice": 600,
  
   "bonusCoinsEarned": 30,

   "paymentType": "Наличными",
   // banknoteForChange - подготовить сдачу с купюры, необязательный параметр, 
   // нужен когда paymentType == PAYMENT_TYPE.CASH, чтобы клиент мог указать купюру (по желанию)
   "banknoteForChange": null,

   // userComment - необязательный параметр
   "userComment": null,
   // responsibleEmployeeComment - необязательный параметр, админ может добавить при создании или обработке заказа
   "responsibleEmployeeComment": null,

   "orderProducts": [
      {
         "productId": 1,
         "quantity": 5,
         "price": 100
      },
      {
         "productId": 2,
         "quantity": 10,
         "price": 99
      }
   ]
}

###
### обрати внимание на PATCH, изменятся только переданные данные (не нужно передавать все поля как в PUT)
### передаешь только те поля, которые нужны для данного действия, например чтобы изменить статус на 
### "отменен" в теле запроса оставляешь только "orderStatus": "отменен",
PATCH {{host}}/orders/48
content-type: application/json

{
   // cityId и restaurantId нужно передавать, только когда нужно именить ресторан для заказа
   // например если ресторан загружен или заказ попал не в тот ресторан по ошибке
   "cityId": 1,
   "restaurantId": 1,
   
   // orderStatus - "отменен" нужно передавать, только когда нужно отменить заказ
   // для смены статусов отдельные роуты ниже, т.к. смена статусов работает по определенному алгоритму
   "orderStatus": "отменен",

   // paymentStatus - для изменения статуса на оплачено при оплате наличными или картой при получении 
   "paymentStatus": "Оплачено",

   "responsibleEmployeeComment": "комментарий от сотрудника"
}

