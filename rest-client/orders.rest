@host=http://localhost:5000/api/v1

# все заказы с пагинацией по умолчанию page=1&perPage=10
GET {{host}}/orders

### пагинация и сортировка
GET {{host}}/orders?sort=id,desc&page=1&perPage=15

###
# получаем только АКТИВНЫЕ заказы с сортировкой от самого нового заказа
GET {{host}}/orders?active=true&sort=id,desc

###
# получаем только НЕАКТИВНЫЕ заказы с сортировкой от самого нового заказа
GET {{host}}/orders?active=false&sort=id,desc

###
# получаем заказы по ресторану с сортировкой от самого нового заказа
GET {{host}}/orders?restaurantId=2&sort=id,desc

###
# получаем заказы по городу с сортировкой от самого нового заказа
GET {{host}}/orders?cityId=1&sort=id,desc

###
# комбинируем параметры фильтров
GET {{host}}/orders?restaurantId=2&active=false&sort=id,desc


