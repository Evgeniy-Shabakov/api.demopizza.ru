content-type: application/json

{
   "bonusCoins": 500,
   // description - необязательный параметр
   "description": "Розыгрыш баварской пиццы для привлечения аудиторию в группу вк"
}

### активация и деактивация кода (изменить можно только неиспользованный промокод)
PATCH {{host}}/promocodes/1
content-type: application/json

{
   "isActive": false
}

